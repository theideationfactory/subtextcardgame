# ===========================================
# SUBTEXT APP ENVIRONMENT CONFIGURATION
# ===========================================
# SECURITY WARNING: Never commit real values!
# Copy this file to .env and fill in your values.
# ===========================================

# Supabase Configuration (Required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Alchemy API Key (for NFT features)
EXPO_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# Pinata API Keys for IPFS storage (for NFT features)
EXPO_PUBLIC_PINATA_API_KEY=your_pinata_api_key
EXPO_PUBLIC_PINATA_SECRET_KEY=your_pinata_secret_key

# NFT Contract Address
EXPO_PUBLIC_NFT_CONTRACT_ADDRESS=your_contract_address

# Blockchain network - Use 'MATIC_AMOY' for testing or 'MATIC_MAINNET' for production
EXPO_PUBLIC_BLOCKCHAIN_NETWORK=MATIC_AMOY

# ===========================================
# DEPLOYMENT ONLY - DO NOT USE IN APP
# ===========================================
# These are ONLY used for smart contract deployment
# NEVER expose these in the mobile app
# DEPLOYER_PRIVATE_KEY=<set only when deploying contracts>
# POLYGONSCAN_API_KEY=<set only when verifying contracts>
